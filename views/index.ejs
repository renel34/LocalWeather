<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Weather</title>
    <link href="/output.css" rel="stylesheet">
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <%- include('header.ejs') %>

    <main class="mx-auto flex min-h-[calc(100vh-9rem)] max-w-6xl flex-col gap-8 px-4 py-10">
      <% if (locals.weatherData) { %>
      <section class="rounded-4xl border border-white/10 bg-slate-900/80 p-8 shadow-2xl shadow-slate-950/30 backdrop-blur-sm">
        <h2 class="mb-8 text-center text-4xl font-semibold text-amber-300 md:text-left">
          <%= weatherData.location %>
        </h2>

        <div class="grid gap-8 md:grid-cols-[280px_1fr]">
          <div class="rounded-4xl bg-slate-950/80 p-8 text-center shadow-inner shadow-slate-950/20">
            <img
              src="http://openweathermap.org/img/wn/<%= weatherData.weatherIcon %>@4x.png"
              alt="<%= weatherData.weatherDescription %>"
              class="mx-auto h-32 w-32"
            />
            <p class="mt-6 text-lg font-semibold capitalize text-amber-300">
              <%= weatherData.weatherDescription.charAt(0).toUpperCase() + weatherData.weatherDescription.slice(1) %>
            </p>
          </div>

          <div class="grid gap-4 rounded-4xl bg-slate-950/80 p-8 text-slate-100 shadow-inner shadow-slate-950/20">
            <p class="text-6xl font-bold text-white">
              <%= weatherData.temperature %>°F
            </p>
            <div class="grid gap-3 text-sm leading-7 text-slate-300 sm:grid-cols-2">
              <p>Feels like: <span class="font-semibold text-slate-100"><%= weatherData.feelsLike %>°F</span></p>
              <p>Humidity: <span class="font-semibold text-slate-100"><%= weatherData.humidity %>%</span></p>
              <p>Min / Max: <span class="font-semibold text-slate-100"><%= weatherData.tempMin %>°F / <%= weatherData.tempMax %>°F</span></p>
              <p>Pressure: <span class="font-semibold text-slate-100"><%= weatherData.pressure.inHg %> inHg</span></p>
              <p>Cloudiness: <span class="font-semibold text-slate-100"><%= weatherData.clouds !== 'N/A' ? weatherData.clouds + '%' : 'N/A' %></span></p>
              <p>Rain (1h): <span class="font-semibold text-slate-100"><%= weatherData.rain %> mm</span></p>
              <p class="sm:col-span-2">
                Wind: <span class="font-semibold text-slate-100"><%= weatherData.wind.speed !== 'N/A' ? weatherData.wind.speed + ' mph' : 'N/A' %></span>
                <% if (weatherData.wind.deg !== 'N/A') { %>
                <span class="text-slate-400">at <%= weatherData.wind.deg %>°</span>
                <% } %>
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="rounded-4xl border border-white/10 bg-slate-900/80 p-8 shadow-2xl shadow-slate-950/30 backdrop-blur-sm">
        <h3 class="mb-6 text-2xl font-semibold text-amber-300">5-Day Forecast</h3>
        <div class="grid gap-4 md:grid-cols-5">
          <% forecastData.forEach(day => { %>
          <article class="rounded-[1.75rem] bg-slate-950/80 p-5 text-center shadow-lg shadow-slate-950/20">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-300"><%= day.date %></p>
            <img
              src="http://openweathermap.org/img/wn/<%= day.icon %>.png"
              alt="<%= day.description %>"
              class="mx-auto my-4 h-16 w-16"
            />
            <p class="text-3xl font-bold text-white"><%= day.temp %>°F</p>
            <p class="mt-2 text-sm text-slate-400 capitalize"><%= day.description %></p>
          </article>
          <% }); %>
        </div>
      </section>
      <% } %>
      <%- include('temperatureChart.ejs') %>
    </main>

    <%- include('footer.ejs') %>

    <script>
      const errorMessage = "<%= locals.error ? error : '' %>";
      if (errorMessage) {
        alert(errorMessage);
      }
    </script>
  </body>
</html>
